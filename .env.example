# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/app.db

# Auth
# Generate a strong random secret (openssl rand -hex 64)
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXPIRES_IN=15m

# CORS, separate each with a comma
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_RATE_LIMIT_MAX=100
RATE_LIMIT_MAX=10

# Cost factor
BCRYPT_ROUNDS=12
